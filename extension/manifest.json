{
  "manifest_version": 3,
  "name": "Job Application Tracker",
  "version": "3.0",
  "description": "Logs jobs you apply to on LinkedIn, Indeed, or Handshake into one growing, formatted Excel file. No server needed.",

  "permissions": ["storage", "unlimitedStorage", "downloads"],

  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.joinhandshake.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Application Tracker"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.joinhandshake.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
