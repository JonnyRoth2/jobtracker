{
  "manifest_version": 3,
  "name": "Job Application Tracker",
  "version": "1.0",

  "permissions": ["storage"],

  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://script.google.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://*.indeed.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}